<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="anchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="towsongroup.fooddoods.CustomerSignUpController">
   <children>
      <Button layoutX="360.0" layoutY="350.0" mnemonicParsing="false" onAction="#attemptSignUp" text="Create Account" />
      <Button layoutX="479.0" layoutY="350.0" mnemonicParsing="false" onAction="#returnToLanding" prefHeight="25.0" prefWidth="96.0" text="Cancel" />
      <Label layoutX="28.0" layoutY="21.0" text="Username">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="userNameField" layoutX="28.0" layoutY="45.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="70.0" text="Password">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="passWordField" layoutX="28.0" layoutY="94.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="119.0" text="Name">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="nameField" layoutX="28.0" layoutY="143.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="168.0" text="Phone Number">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="phoneNumberField" layoutX="28.0" layoutY="192.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="217.0" text="eMail Address">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="eMailAddressField" layoutX="28.0" layoutY="241.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="271.0" text="Street Address">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="addressField" layoutX="28.0" layoutY="295.0" prefHeight="25.0" prefWidth="147.0" />
      <Label layoutX="28.0" layoutY="326.0" text="Credit Card Number">
         <padding>
            <Insets top="5.0" />
         </padding>
      </Label>
      <TextField fx:id="paymentField" layoutX="28.0" layoutY="350.0" prefHeight="25.0" prefWidth="147.0" />
   </children>
</AnchorPane>
