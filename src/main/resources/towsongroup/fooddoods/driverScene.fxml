<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="anchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="towsongroup.fooddoods.DriverController">
   <children>
      <TabPane prefHeight="400.0" prefWidth="600.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Available Orders">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <ScrollPane layoutX="14.0" layoutY="14.0" prefHeight="279.0" prefWidth="572.0">
                           <content>
                              <ListView prefHeight="467.0" prefWidth="556.0" />
                           </content>
                        </ScrollPane>
                        <Button layoutX="489.0" layoutY="318.0" mnemonicParsing="false" text="Accept Order" />
                        <Button layoutX="373.0" layoutY="318.0" mnemonicParsing="false" text="Reject Order" />
                     </children></AnchorPane>
            </content>
          </Tab>
          <Tab text="Current Order">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Button layoutX="14.0" layoutY="332.0" mnemonicParsing="false" text="Mark Order as Picked Up" />
                        <Button layoutX="426.0" layoutY="332.0" mnemonicParsing="false" text="Mark Order as Dropped Off" />
                     </children></AnchorPane>
            </content>
          </Tab>
            <Tab text="Account">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Button layoutX="474.0" layoutY="322.0" mnemonicParsing="false" onAction="#returnToLanding" text="Update Account" />
                        <Button layoutX="353.0" layoutY="322.0" mnemonicParsing="false" onAction="#attemptUpdate" prefHeight="25.0" prefWidth="100.0" text="Log Out" />
                        <Label layoutX="26.0" layoutY="49.0" text="Username">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="userNameField" layoutX="24.0" layoutY="73.0" prefHeight="25.0" prefWidth="147.0" />
                        <Label layoutX="28.0" layoutY="99.0" text="Password">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="passWordField" layoutX="24.0" layoutY="123.0" prefHeight="25.0" prefWidth="147.0" />
                        <Label layoutX="27.0" layoutY="149.0" text="Name">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="nameField" layoutX="25.0" layoutY="173.0" prefHeight="25.0" prefWidth="147.0" />
                        <Label layoutX="27.0" layoutY="201.0" text="Phone Number">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="phoneNumberField" layoutX="24.0" layoutY="225.0" prefHeight="25.0" prefWidth="147.0" />
                        <Label layoutX="25.0" layoutY="251.0" text="eMail Address">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="eMailAddressField" layoutX="25.0" layoutY="275.0" prefHeight="25.0" prefWidth="147.0" />
                        <Label layoutX="25.0" layoutY="300.0" text="Vehicle Number">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                        </Label>
                        <TextField fx:id="vehicleField" layoutX="25.0" layoutY="322.0" prefHeight="25.0" prefWidth="147.0" />
                     </children>
                  </AnchorPane>
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
